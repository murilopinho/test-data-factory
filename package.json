{
  "name": "cypress-ecommerce-suite",
  "version": "1.0.0",
  "description": "Suite de testes E2E para ecommerce usando Cypress com Page Object Model",
  "scripts": {
    "test": "cypress run",
    "test:headed": "cypress open",
    "test:chrome": "cypress run --browser chrome",
    "test:report": "cypress run --reporter mochawesome --reporter-options reportDir=reports,overwrite=false,html=true,json=false"
  },
  "keywords": ["cypress", "e2e", "testing", "page-object-model", "qa", "ecommerce"],
  "author": "Murilo Pinho",
  "license": "MIT",
  "devDependencies": {
    "cypress": "13.6.6",
    "mochawesome": "7.1.3",
    "mochawesome-merge": "4.3.0",
    "mochawesome-report-generator": "6.2.0"
  }
}
